<UserControl x:Class="PlayniteSense.PlayniteSenseSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="680" d:DesignWidth="560">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="12">
            <TextBlock Text="PlayniteSense — DualSense Virtual Controller Bridge"
                       FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>

            <Separator Margin="0,4,0,10"/>
            <TextBlock Text="Diagnostics" FontWeight="Bold" Margin="0,0,0,6"/>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <TextBlock Text="Virtual controller type:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox Name="cmbTargetMode" SelectedIndex="0" Width="130">
                    <ComboBoxItem Content="Xbox 360"/>
                    <ComboBoxItem Content="DualShock 4"/>
                </ComboBox>
            </StackPanel>

            <WrapPanel Margin="0,0,0,6">
                <Button Name="btnTestPad" Content="Test Physical Controller"
                        Click="BtnTestPad_Click" Padding="9,4" Margin="0,0,6,6"/>
                <Button Name="btnCheckDriver" Content="Check Required Drivers"
                        Click="BtnCheckDriver_Click" Padding="9,4" Margin="0,0,6,6"/>
            </WrapPanel>

            <WrapPanel Margin="0,0,0,6">
                <Button Name="btnStartBridge" Content="Start Controller Bridge"
                        Click="BtnStartBridge_Click" Padding="9,4" Margin="0,0,6,6"/>
                <Button Name="btnStopBridge" Content="Stop Controller Bridge"
                        Click="BtnStopBridge_Click" Padding="9,4" Margin="0,0,6,6"/>
            </WrapPanel>

            <Button Name="btnClearLog" Content="Clear Diagnostic Log" Click="BtnClearLog_Click"
                    Padding="9,4" HorizontalAlignment="Left"/>

            <TextBlock Text="Physical Controller Input"
                       Margin="0,10,0,2" FontWeight="SemiBold"/>
            <TextBlock Name="txtRawPad" FontFamily="Consolas" FontSize="12"
                       Text="—" TextWrapping="Wrap"/>

            <TextBlock Text="Diagnostic Log" Margin="0,10,0,2" FontWeight="SemiBold"/>
            <TextBox Name="txtLog" FontFamily="Consolas" FontSize="11" Height="140"
                     IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                     Background="#1E1E1E" Foreground="#D4D4D4" BorderThickness="1"/>

            <TextBlock Text="Virtual Controller Output"
                       Margin="0,10,0,2" FontWeight="SemiBold"/>
            <TextBlock Text="Monitored automatically while the bridge is running."
                       FontSize="11" Foreground="#B8B8B8" Margin="0,0,0,2"/>
            <TextBlock Name="txtXInput" FontFamily="Consolas" FontSize="12"
                       Text="Bridge is stopped." TextWrapping="Wrap" Margin="0,0,0,10"/>

            <Separator Margin="0,5,0,10"/>
            <TextBlock Text="Requirements" FontWeight="Bold" FontSize="12"
                       Foreground="Orange" Margin="0,0,0,4"/>
            <Border Background="#252526" BorderBrush="#3F3F46" BorderThickness="1" Padding="10">
                <StackPanel>
                    <TextBlock Margin="0,0,0,3" TextWrapping="Wrap">
                        <Hyperlink NavigateUri="https://github.com/nefarius/ViGEmBus/releases/"
                                   RequestNavigate="Hyperlink_RequestNavigate">
                            <Run Text="ViGEmBus"/>
                        </Hyperlink>
                        <Run Text=" and " Foreground="#DCDCDC"/>
                        <Hyperlink NavigateUri="https://github.com/nefarius/HidHide/releases/"
                                   RequestNavigate="Hyperlink_RequestNavigate">
                            <Run Text="HidHide"/>
                        </Hyperlink>
                    </TextBlock>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
